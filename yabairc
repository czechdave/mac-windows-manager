#!/usr/bin/env sh

# yabai configuration - float layout (no SIP modification needed)
# Manual tiling via custom scripts

# Use float layout by default - we handle tiling manually
yabai -m config layout float

# Window appearance
yabai -m config window_shadow on
yabai -m config window_opacity off

# Mouse settings
yabai -m config mouse_follows_focus off
yabai -m config focus_follows_mouse off
yabai -m config mouse_modifier fn
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize

# Padding (space around windows)
yabai -m config top_padding    0
yabai -m config bottom_padding 0
yabai -m config left_padding   0
yabai -m config right_padding  0
yabai -m config window_gap     0

# Signals to auto-tile on window changes
yabai -m signal --add event=window_created action="$HOME/scripts/tile-equal.sh"
yabai -m signal --add event=window_destroyed action="$HOME/scripts/tile-equal.sh"
yabai -m signal --add event=window_minimized action="$HOME/scripts/tile-equal.sh"
yabai -m signal --add event=window_deminimized action="$HOME/scripts/tile-equal.sh"
yabai -m signal --add event=application_hidden action="$HOME/scripts/tile-equal.sh"
yabai -m signal --add event=application_visible action="$HOME/scripts/tile-equal.sh"

# Signals for space/desktop changes (handles window drag between spaces)
yabai -m signal --add event=space_changed action="$HOME/scripts/space-changed.sh"
yabai -m signal --add event=mission_control_exit action="$HOME/scripts/tile-equal.sh"

# Signals for display/monitor changes (handles window drag between displays)
yabai -m signal --add event=display_changed action="$HOME/scripts/display-changed.sh"
yabai -m signal --add event=window_moved action="$HOME/scripts/window-moved.sh"

echo "yabai configuration loaded"
